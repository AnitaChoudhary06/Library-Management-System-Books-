}

//Generate Bill
void Generate_Bill(){
    int ID, i, found = 0;
    
    printf("Enter Patient_ID: ");
    scanf("%d", &ID);
    
    for(i = 0; i < count; i++){
        if(P[i].Patient_ID == ID){
            int room = 500;
            int Doctor = 1000;
            int Medicine = 300;
            
            P[i].Patient_Bill = (P[i].Patient_AdmissionDate * room) + Doctor + Medicine;
            
            printf("\n=======BILL=======\n");
            printf("Patient_Name: %s\n", &P[i].Patient_Name);
            printf("Assigned_Doctor: %s\n", &P[i].Assigned_Doctor);
            printf("Total Bill: %d\n", &P[i].Patient_Bill);
            
            found = 1;
        }
    }
    
    if(found == 0){
        printf("Patient is not found!\n");
    }
}


//Main Program
int main(){
    int choice;
    
    while(1){
        printf("\n=======Hospitai Management System========\n");
        printf("1. Add_Patient\n");
        printf("2. View_Patient\n");
        printf("3. Search_Patient\n");
        printf("4. Assigned_Doctor\n");
        printf("5. Generate_Bill\n");
        printf("6. Exit\n");
        
        printf("Enter the choice: ");
        scanf("%d", &choice);
        
        switch(choice){
            case 1:
            Add_Patient();
            break;
            
            case 2:
            View_Patient();
            break;
            
            case 3: 
            Search_Patient(); 
            break;
            
            case 4:
            Assigned_Doctor(); 
            break;
            
            case 5: 
            Generate_Bill(); 
            break;
            
            case 6: 
            return 0;
            
            default: 
            printf("Invalid Choice!\n");
        }
    }
}


